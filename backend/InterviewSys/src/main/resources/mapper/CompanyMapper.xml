<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cuit.interviewsystem.mapper.CompanyMapper">

    <resultMap id="BaseResultMap" type="com.cuit.interviewsystem.model.entity.Company">
            <id property="companyId" column="company_id" />
            <result property="adminId" column="admin_id" />
            <result property="companyName" column="company_name" />
            <result property="logoUrl" column="logo_url" />
            <result property="website" column="website" />
            <result property="introduction" column="introduction" />
            <result property="industry" column="industry" />
            <result property="scale" column="scale" />
            <result property="city" column="city" />
            <result property="status" column="status" />
            <result property="businessLicenseUrl" column="business_license_url" />
            <result property="isDeleted" column="is_deleted" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
            <result property="editTime" column="edit_time" />
    </resultMap>

    <resultMap id="CompanyVoResultMap" type="com.cuit.interviewsystem.model.vo.CompanyVo">
        <id property="companyId" column="company_id" />
        <result property="adminId" column="admin_id" />
        <result property="adminName" column="admin_name" />
        <result property="companyName" column="company_name" />
        <result property="logoUrl" column="logo_url" />
        <result property="website" column="website" />
        <result property="introduction" column="introduction" />
        <result property="industry" column="industry" />
        <result property="scale" column="scale" />
        <result property="city" column="city" />
        <result property="status" column="status" />
        <result property="businessLicenseUrl" column="business_license_url" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="Base_Column_List">
        company_id,admin_id,company_name,logo_url,website,introduction,
        industry,scale,city,status,business_license_url,
        is_deleted,create_time,update_time,edit_time
    </sql>
    <select id="getCompanyVoById" resultType="com.cuit.interviewsystem.model.vo.CompanyVo">
        SELECT
            c.*,u.username as admin_name
        FROM t_company c
        LEFT JOIN t_user u ON c.admin_id = u.user_id
        WHERE c.company_id = #{companyId}
        AND c.is_deleted = 0 AND c.status = 1;
    </select>
    <select id="getCompanyVoPage" resultType="com.cuit.interviewsystem.model.vo.CompanyVo">
        SELECT
            c.*,u.username as admin_name
        FROM t_company c
                 LEFT JOIN t_user u ON c.admin_id = u.user_id
        WHERE
        <if test="dto.companyName != null">
            AND c.company_name LIKE CONCAT('%',#{dto.companyName},'%')
        </if>
        <if test="dto.industry != null">
            AND c.industry = #{dto.industry}
        </if>
        <if test="dto.scale != null">
            AND c.scale = #{dto.scale}
        </if>
        <if test="dto.city != null">
            AND c.city = #{dto.city}
        </if> AND c.is_deleted = 0 AND c.status = 1
    </select>
</mapper>
